DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/equivoz
SECRET_KEY=troque-este-segredo-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# URL do front (link de “esqueci a senha” no e-mail), ex.: https://equivoz.netlify.app
APP_PUBLIC_URL=https://equivoz.netlify.app

# E-mail — opcional; sem SMTP o pedido de redefinição grava o token, mas o utilizador
# precisa de `LOG_PASSWORD_RESET_LINK_SEM_SMTP=true` (só dev) para ver a URL no log
# ou configurar SMTP em produção.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@exemplo.com
# SMTP_USE_TLS=true
# PASSWORD_RESET_TOKEN_HORAS=1
# LOG_PASSWORD_RESET_LINK_SEM_SMTP=false

# CORS: origens do front (Netlify, etc.), separadas por vírgula, sem espaços a mais
# CORS_ORIGINS=https://equivoz.netlify.app,https://id-deploy--equivoz.netlify.app
