DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/equivoz
SECRET_KEY=troque-este-segredo-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Onde o utilizador abre o site (sem / no fim) — gera o link de redefinir senha nos e-mails
# Dev: http://localhost:5173  |  Produção: https://equivoz.netlify.app
APP_PUBLIC_URL=https://equivoz.netlify.app

# Brevo — duas formas (use UMA)
#
# 1) API (recomendado no Heroku): a chave "xkeysib-…" em Definições → Chaves de API (não precisa de biblioteca sib_api_v3; o nosso código chama a API por HTTPS).
#    Com BREVO_API_KEY definida, o SMTP abaixo é ignorado.
# BREVO_API_KEY=xkeysib-...
#
# 2) SMTP: Definições → SMTP e API → separador *SMTP* (host, login e senha de SMTP; não confundir com a chave xkeysib se a autenticação falhar)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=seu_login@smtp-brevo.com
SMTP_PASSWORD=chave_smtp_do_separador_smtp
# Remetente: tem de estar verificado em Brevo → Definições → Remetentes
SMTP_FROM=remetente@seudominio.com
SMTP_USE_TLS=true
PASSWORD_RESET_TOKEN_HORAS=1
# Só em dev, sem Brevo: coloca a URL de redefinição no log do servidor
LOG_PASSWORD_RESET_LINK_SEM_SMTP=false

# CORS: origens do front (Netlify, deploy previews), separadas por vírgula
# CORS_ORIGINS=https://equivoz.netlify.app,https://id--equivoz.netlify.app
