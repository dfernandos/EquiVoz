DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/equivoz
SECRET_KEY=troque-este-segredo-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# URL pública do front (link no e-mail de confirmação; use o domínio Netlify em produção)
APP_PUBLIC_URL=https://seu-site.netlify.app

# E-mail (opcional em dev; em produção configure SMTP, ex. SendGrid, Mailgun, Gmail com app password)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@seudominio.com
# SMTP_USE_TLS=true
# VERIFICACAO_EMAIL_HORAS=48
# Só em dev: imprimir o link no log se não houver SMTP
# LOG_LINK_VERIFICACAO_SE_SEM_SMTP=false

# CORS: origens do front (Netlify, etc.), separadas por vírgula, sem espaços a mais
# CORS_ORIGINS=https://equivoz.netlify.app,https://id-deploy--equivoz.netlify.app
